<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>

<GridPane fx:controller="com.example.simul2d.JavaFX.InitController"
          xmlns:fx="http://javafx.com/fxml" hgap="8" vgap="8"
          style="-fx-padding: 12; -fx-border-color: #888; -fx-border-width: 1;">

    <Label text="Grid Width:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
    <TextField fx:id="widthField" GridPane.rowIndex="0" GridPane.columnIndex="1" />

    <Label text="Grid Height:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
    <TextField fx:id="heightField" GridPane.rowIndex="1" GridPane.columnIndex="1" />

    <Label text="Toric grid:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
    <CheckBox fx:id="toricBox" GridPane.rowIndex="2" GridPane.columnIndex="1" />

    <Label fx:id="errorLabel" style="-fx-text-fill: red;" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.columnSpan="2" />

    <Button fx:id="validateButton" text="Valider" GridPane.rowIndex="4" GridPane.columnIndex="0" GridPane.columnSpan="2" />

</GridPane>
